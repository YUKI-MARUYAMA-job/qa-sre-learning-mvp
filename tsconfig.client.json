{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "types": [
      "bun",
      "vite/client"
    ],
    "noEmit": true
  },
  "include": [
    "src/client/**/*.ts",
    "src/client/**/*.tsx",
    "src/schemas/**/*.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "reports"
  ]
}
