{
  "name": "qa-sre-learning-mvp",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "^1.3.14"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "validate:data": "bun run src/cli/validate-data.ts",
    "validate:policy": "bun run src/cli/validate-policy.ts",
    "report": "bun run src/cli/generate-report.ts",
    "check": "bun run typecheck && bun test && bun run validate:data && bun run validate:policy",
    "build": "bun run check && mkdir -p dist && cp -R reports dist/reports && cp README.md dist/index.md"
  }
}
