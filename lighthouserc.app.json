{
  "ci": {
    "collect": {
      "staticDistDir": "./dist/app",
      "url": [
        "http://localhost/"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--headless=new --no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.8,
            "aggregationMethod": "median"
          }
        ],
        "categories:accessibility": [
          "warn",
          {
            "minScore": 0.9,
            "aggregationMethod": "median"
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.9,
            "aggregationMethod": "median"
          }
        ],
        "categories:seo": [
          "warn",
          {
            "minScore": 0.8,
            "aggregationMethod": "median"
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci/app-reports"
    }
  }
}