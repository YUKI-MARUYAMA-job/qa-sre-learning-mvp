{
  "ci": {
    "collect": {
      "staticDistDir": "./dist/site",
      "url": [
        "http://localhost/",
        "http://localhost/quality-report.html",
        "http://localhost/portfolio-readiness.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8, "aggregationMethod": "median" }],
        "categories:accessibility": ["warn", { "minScore": 0.9, "aggregationMethod": "median" }],
        "categories:best-practices": ["warn", { "minScore": 0.9, "aggregationMethod": "median" }],
        "categories:seo": ["warn", { "minScore": 0.8, "aggregationMethod": "median" }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci/reports"
    }
  }
}
